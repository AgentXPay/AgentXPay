{
  "name": "agentxpay",
  "version": "0.1.0",
  "private": true,
  "description": "AgentXPay - AI Agent Native Payment Infrastructure on Monad",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "clean": "turbo clean",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "sdk:build": "cd sdk && pnpm build",
    "middleware:build": "cd middleware && pnpm build",
    "frontend:dev": "cd frontend && pnpm dev",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "indexer:dev": "pnpm --filter @agentxpay/indexer dev",
    "indexer:build": "pnpm --filter @agentxpay/indexer build",
    "indexer:start": "pnpm --filter @agentxpay/indexer start",
    "demo:provider": "cd demo && pnpm run provider",
    "demo:agent": "cd demo && pnpm run agent"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0"
}
