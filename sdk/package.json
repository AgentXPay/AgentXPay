{
  "name": "@agentxpay/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentXPay - AI Agent Payment Infrastructure on Monad blockchain. Supports x402 protocol, service discovery, payments, subscriptions, escrow, and agent wallet management.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentxpay",
    "monad",
    "blockchain",
    "x402",
    "ai-agent",
    "payment",
    "web3",
    "ethereum",
    "service-discovery",
    "escrow",
    "subscription"
  ],
  "author": "jasonruan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonRUAN/agentxpay.git"
  },
  "homepage": "https://github.com/JasonRUAN/agentxpay#readme",
  "bugs": {
    "url": "https://github.com/JasonRUAN/agentxpay/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
